<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiApp1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiApp1"
    FlyoutBehavior="Flyout"
    Title="Мои финансы">

    <FlyoutItem Title="Главная" Route="home">
        <ShellContent
            Title="Мои финансы"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
    </FlyoutItem>
    <FlyoutItem Title="Отчеты" Route="reports">
        <ShellContent
            Title="Отчеты"
            ContentTemplate="{DataTemplate local:ReportPage}"
            Route="ReportPage" />
    </FlyoutItem>

    <FlyoutItem Title="Категории" Route="categories">
        <ShellContent
            Title="Категории"
            ContentTemplate="{DataTemplate local:CategoriesPage}"
            Route="CategoriesPage" />
    </FlyoutItem>
</Shell>
