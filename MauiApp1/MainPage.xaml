<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.MainPage"
             Title="Мои финансы">

    <Grid RowDefinitions="2*,6*,2*"
          RowSpacing="10"
          Padding="16">
        <!-- Верхняя область -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="Мои финансы"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            
            <Label x:Name="BalanceLabel"
                   Text="25 000 ₽"
                   FontSize="34"
                   HorizontalOptions="Center" />
            
            <ProgressBar x:Name="BalanceProgressBar"
                         Progress="0.65"
                         HeightRequest="12" />
        </VerticalStackLayout>
        <!-- Центральная область -->
        <CollectionView Grid.Row="1"
                        x:Name="TransactionCollectionView"
                        ItemsSource="{Binding Transactions}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          Padding="0,8">
                        <Label Text="{Binding CategoryIcon}"
                               FontSize="24"
                               VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="10,0,0,0">
                            <Label Text="{Binding Description}" FontSize="16" />
                            <Label Text="{Binding Date}" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>

                        <Label Grid.Column="2"
                               Text="{Binding Amount, StringFormat='{}{0:N0} ₽'}"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Нижняя панель -->
        <HorizontalStackLayout Grid.Row="2"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Spacing="12">
            <Button Text="Доход" Clicked="OnIncomeButtonClicked" />
            <Button Text="Расход" Clicked="OnExpenseButtonClicked" />
            <Button Text="Отчеты" Clicked="OnReportButtonClicked" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
